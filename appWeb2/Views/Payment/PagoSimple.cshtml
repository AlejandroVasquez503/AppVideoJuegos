@{
    ViewData["Title"] = "Pago Simple";
}
<!-- Meta tags para evitar bloqueo de Tracking Prevention en Edge -->
<meta http-equiv="Permissions-Policy" content="storage=https://www.paypal.com https://www.sandbox.paypal.com">

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4>Pagar con PayPal - Prueba</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <h5>Detalles del Producto</h5>
                            <p><strong>Producto:</strong> @ViewBag.NombreJuego</p>
                            <p><strong>ID:</strong> @ViewBag.JuegoId</p>
                            <p><strong>Categoría:</strong> @ViewBag.Categoria</p>
                            <p><strong>Cantidad:</strong> 1</p>
                            <hr>
                            <h4 class="text-primary">Total: $@ViewBag.Monto USD</h4>
                        </div>
                        <div class="col-md-4">
                            <h5>Descripción</h5>
                            <p class="text-muted">@ViewBag.Descripcion</p>
                        </div>
                        <div class="col-md-4">
                            <h5>Método de Pago</h5>
                            <div id="paypal-button-container"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Script de PayPal -->
<script src="https://www.paypal.com/sdk/js?client-id=ASRLqkVcGuPjeTBpDM6N6MJufCYhvpj64uLb9S7PzJaslxKnMIe4uOvf9e8N0jhWgmL5sX4gV3esv0YW&currency=USD&disable-funding=credit,card&intent=capture"></script>

<script>
    paypal.Buttons({
        createOrder: function(data, actions) {
            // Usar el monto del ViewBag
            const amount = @ViewBag.Monto;

            return fetch('/Payment/CreateOrder', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                body: JSON.stringify({
                    amount: parseFloat(amount),
                    description: 'Compra de Videojuego - ID: @ViewBag.JuegoId'
                })
            })
                .then(function(res) {
                    if (!res.ok) {
                        throw new Error('Error al crear la orden');
                    }
                    return res.json();
                })
                .then(function(orderData) {
                    return orderData.id;
                })
                .catch(function(err) {
                    console.error('Error:', err);
                    alert('Error al crear la orden de PayPal');
                });
        },

        onApprove: function(data, actions) {
            // El usuario aprobó en PayPal, redirigir a nuestro endpoint
            console.log('=== PAYPAL ONAPPROVE ===');
            console.log('Orden aprobada:', data);
            console.log('OrderID:', data.orderID);
            console.log('PayerID:', data.payerID);
            
            const redirectUrl = '/Payment/ApproveOrder?token=' + data.orderID;
            console.log('Redirigiendo a:', redirectUrl);
            
            // Forzar la redirección después de un pequeño delay
            setTimeout(function() {
                window.location.href = redirectUrl;
            }, 1000);
        },

        onError: function(err) {
            console.error('Error en PayPal:', err);
            alert('Hubo un error procesando el pago. Por favor intenta nuevamente.');
        },

        onCancel: function(data) {
            console.log('Pago cancelado:', data);
            window.location.href = '/Payment/CancelOrder';
        }
    }).render('#paypal-button-container');
</script>

@Html.AntiForgeryToken()
