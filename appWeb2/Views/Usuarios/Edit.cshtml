@model appWeb2.Models.Usuario
@{
    ViewData["Title"] = "Editar Usuario";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <h2 class="mb-4">
        <i class="fas fa-user-edit me-2"></i>Editar Usuario
    </h2>

    <div class="card">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">Modificar Información</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="nombre" class="control-label">Nombre</label>
                            <input asp-for="nombre" class="form-control" />
                            <span asp-validation-for="nombre" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="correo" class="control-label">Correo</label>
                            <input asp-for="correo" class="form-control" type="email" readonly />
                            <span asp-validation-for="correo" class="text-danger"></span>
                            <small class="text-muted">El correo no se puede modificar</small>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="password" class="control-label">Nueva Contraseña</label>
                            <input asp-for="password" class="form-control" type="password" placeholder="Deje en blanco para mantener la actual" />
                            <span asp-validation-for="password" class="text-danger"></span>
                            <small class="text-muted">Solo si desea cambiar la contraseña</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="idRol" class="control-label">Rol</label>
                            <select asp-for="idRol" class="form-control" asp-items="ViewBag.Roles">
                                <option value="">-- Seleccione un rol --</option>
                            </select>
                            <span asp-validation-for="idRol" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-save me-2"></i>Guardar Cambios
                    </button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        <i class="fas fa-arrow-left me-2"></i>Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
