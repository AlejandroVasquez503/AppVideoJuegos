@model IEnumerable<appWeb2.Models.VentaViewModel>
@{
    Layout = "~/Views/Shared/_LayoutSinBanner.cshtml";
    ViewData["Title"] = "Detalle de Ventas";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="text-primary mb-0">Reporte de Ventas</h2>
                <a href="@Url.Action("Dashboard", "Account")" class="btn btn-outline-primary">
                    Regresar al Dashboard
                </a>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Filtrar Ventas</h5>
        </div>
        <div class="card-body">
            <form asp-action="DetalleVentas" method="get" class="row g-3">
                <div class="col-md-3">
                    <label for="desde" class="form-label">Desde:</label>
                    <input type="date" name="desde" id="desde" 
                           value="@ViewBag.Desde?.ToString("yyyy-MM-dd")" 
                           class="form-control" />
                </div>
                <div class="col-md-3">
                    <label for="hasta" class="form-label">Hasta:</label>
                    <input type="date" name="hasta" id="hasta" 
                           value="@ViewBag.Hasta?.ToString("yyyy-MM-dd")" 
                           class="form-control" />
                </div>
                <div class="col-md-3">
                    <label for="clienteId" class="form-label">Cliente:</label>
                    <select name="clienteId" id="clienteId" class="form-control">
                        <option value="">-- Todos los clientes --</option>
                        @if (ViewBag.Clientes != null)
                        {
                            @foreach (var cliente in ViewBag.Clientes)
                            {
                                <option value="@cliente.Id" selected="@(ViewBag.ClienteId?.ToString() == cliente.Id.ToString())">
                                    @cliente.nombre
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="videojuegoId" class="form-label">Videojuego:</label>
                    <select name="videojuegoId" id="videojuegoId" class="form-control">
                        <option value="">-- Todos los videojuegos --</option>
                        @if (ViewBag.Videojuegos != null)
                        {
                            @foreach (var juego in ViewBag.Videojuegos)
                            {
                                <option value="@juego.Id" selected="@(ViewBag.VideojuegoId?.ToString() == juego.Id.ToString())">
                                    @juego.titulo
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary me-2">
                        Filtrar
                    </button>
                    <a href="@Url.Action("DetalleVentas")" class="btn btn-secondary">
                        Limpiar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Botones de Exportación -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <span class="text-muted">
                        <strong>Total de registros:</strong> @Model.Count()
                    </span>
                </div>
                <div>
                    <form asp-action="ExportarPDF" method="get" class="d-inline">
                        <input type="hidden" name="desde" value="@ViewBag.Desde?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="hasta" value="@ViewBag.Hasta?.ToString("yyyy-MM-dd")" />
                        <button type="submit" class="btn btn-danger">
                            Exportar a PDF
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Ventas -->
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Detalles de Ventas</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>ID Compra</th>
                            <th>Usuario</th>
                            <th>Videojuego</th>
                            <th>Cantidad</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th>Código</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var venta in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-primary">@venta.idCompra</span>
                                    </td>
                                    <td>@venta.NombreUsuario</td>
                                    <td>@venta.NombreVideojuego</td>
                                    <td>@venta.cantidad</td>
                                    <td>
                                        <strong>$@venta.total.ToString("F2")</strong>
                                    </td>
                                    <td>
                                        @{
                                            var estadoClass = venta.estadoCompra?.ToLower() switch
                                            {
                                                "completado" => "success",
                                                "pendiente" => "warning",
                                                "cancelado" => "danger",
                                                _ => "secondary"
                                            };
                                        }
                                        <span class="badge bg-@estadoClass">@venta.estadoCompra</span>
                                    </td>
                                    <td>@venta.fechaHoraTransaccion.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <code>@venta.codigoTransaccion</code>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <p>No se encontraron ventas en el período especificado.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (Model != null && Model.Any())
                    {
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="3" class="text-end">TOTAL:</th>
                                <th colspan="4">
                                    <strong class="text-success">
                                        $@Model.Sum(v => v.total).ToString("F2")
                                    </strong>
                                </th>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>

    <!-- Paginación -->
    @if (ViewBag.TotalPaginas > 1)
    {
        <div class="row mt-4">
            <div class="col-12">
                <nav aria-label="Paginación">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                        {
                            var activeClass = i == ViewBag.PaginaActual ? "active" : "";
                            <li class="page-item @activeClass">
                                <a class="page-link" 
                                   href="@Url.Action("DetalleVentas", new { 
                                       pagina = i, 
                                       desde = ViewBag.Desde?.ToString("yyyy-MM-dd"), 
                                       hasta = ViewBag.Hasta?.ToString("yyyy-MM-dd") 
                                   })">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>