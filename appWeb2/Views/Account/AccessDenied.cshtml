@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="container mt-5">
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading">Acceso Denegado</h4>
        <p>Lo sentimos, no tienes permisos para acceder a esta página.</p>
        <hr>
        <p class="mb-0">Si crees que esto es un error, por favor contacta con el administrador.</p>
    </div>

    <div class="mt-3">
        <a href="/" class="btn btn-primary">Volver al inicio</a>
        <a href="/Account/Logout" class="btn btn-secondary">Cerrar sesión</a>
    </div>
</div>
