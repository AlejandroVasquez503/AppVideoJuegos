@model IEnumerable<appWeb2.Models.VideoJuegos>
@{
    ViewData["Title"] = "Mis Juegos";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="text-center">
                <h2 class="text-primary mb-2">Mis Juegos</h2>
                <p class="text-muted">Aquí están todos los videojuegos que has comprado</p>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Filtrar Mis Juegos</h5>
        </div>
        <div class="card-body">
            <form asp-action="MisJuegos" method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="nombreJuego" class="form-label">Nombre del Juego:</label>
                    <input type="text" name="nombreJuego" id="nombreJuego" 
                           value="@ViewBag.NombreJuego" 
                           class="form-control" placeholder="Buscar por nombre..." />
                </div>
                <div class="col-md-3">
                    <label for="desde" class="form-label">Comprado Desde:</label>
                    <input type="date" name="desde" id="desde" 
                           value="@ViewBag.Desde?.ToString("yyyy-MM-dd")" 
                           class="form-control" />
                </div>
                <div class="col-md-3">
                    <label for="hasta" class="form-label">Comprado Hasta:</label>
                    <input type="date" name="hasta" id="hasta" 
                           value="@ViewBag.Hasta?.ToString("yyyy-MM-dd")" 
                           class="form-control" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-success me-2">
                        Filtrar
                    </button>
                    <a href="@Url.Action("MisJuegos")" class="btn btn-secondary">
                        Limpiar
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var juego in Model)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="card game-card h-100">
                        <!-- BADGE SUPERIOR -->
                        <div class="badge-top">@juego.EdadMinima</div>

                        <!-- IMAGEN -->
                        <img src="@juego.imagen"
                             class="card-img-top game-img" alt="@juego.titulo" />

                        <div class="card-body d-flex flex-column">
                            <!-- TÍTULO -->
                            <h5 class="card-title fw-bold">
                                @juego.titulo
                            </h5>

                            <!-- PRECIO -->
                            <h4 class="price mt-2">
                                $@juego.precio
                            </h4>

                            <!-- CATEGORÍA -->
                            <div class="mb-2">
                                <span class="text-muted">@juego.Categoria?.categoria</span>
                            </div>

                            <!-- BADGE DE PROMOCIÓN -->
                            @if (juego.EnPromocion)
                            {
                                <div class="mb-2">
                                    <span class="badge bg-success">En Promoción</span>
                                </div>
                            }

                            <!-- FECHA DE COMPRA -->
                            <div class="mt-auto">
                                <small class="text-muted">
                                    Comprado el: @juego.FechaCreacion.ToString("dd/MM/yyyy")
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- BOTONES DE ACCIÓN -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="text-center">
                    <h4 class="mb-3">Mi Biblioteca Personal</h4>
                </div>
            </div>
        </div>

        <!-- RESUMEN -->
        <div class="row mt-4">
            <div class="col-12">
                <div>
                    <div>
                        <h5 class="card-title mb-4 text-white">
                            Resumen de tu Biblioteca
                        </h5>
                        <div class="row text-center">
                            <div class="col-md-4">
                                <h3 class="text-primary">@Model.Count()</h3>
                                <p class="text-muted mb-0">Total de Juegos</p>
                            </div>
                            <div class="col-md-4">
                                <h3 class="text-success">$@Model.Sum(j => j.precio).ToString("F2")</h3>
                                <p class="text-muted mb-0">Total Invertido</p>
                            </div>
                            <div class="col-md-4">
                                <h3 class="text-warning">@Model.Count(j => j.EnPromocion)</h3>
                                <p class="text-muted mb-0">En Promoción</p>
                            </div>
                        </div>
                    </div>
                    <div class="text-center mt-4">
                        <a href="@Url.Action("ExportarMisJuegosPDF", "Account")" class="btn btn-success btn-lg">
                            Descargar PDF
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                <div class="text-center py-5">
                    <h3 class="text-muted">No tienes juegos comprados aún</h3>
                    <p class="text-muted mb-4">Explora nuestro catálogo y encuentra tu próxima aventura</p>
                    <a href="@Url.Action("JuegosVentas", "VideoJuegos")" class="btn btn-primary">
                        Ir a la Tienda
                    </a>
                </div>
            </div>
        </div>
    }
</div>
